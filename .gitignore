# General Ignore Rules
*.log
*.tmp
*.iml

# Server JARs (download these separately, don't version them)
*.jar

# World data (these are generated by the server and are huge)
# If your server.properties has a different level-name, add that folder here.
world/
world_nether/
world_the_end/

# Server-generated dynamic files
logs/
cache/
libraries/
crash-reports/

# Player data and statistics
usercache.json
ops.json
whitelist.json
banned-ips.json
banned-players.json
stats/
playerdata/
advancements/

# Plugin-specific data that should not be versioned
# This is tricky: You want plugin *configs*, but not plugin *data*.
# Example: If a plugin stores an SQLite database in its folder:
plugins/*/data.db
plugins/*/cache/
# You'll need to add more specific lines here as you add plugins
# that generate runtime data you don't want to track.
# Generally, avoid committing plugin .jar files here if your /servers/lobby/plugins/
# folder just holds config directories.

# EULA (Optional: Can be committed if you agree to it, or ignored if you want a clean repo)
# If you commit it, make sure eula=true.
# eula.txt