# /etc/caddy/Caddyfile
# Global configuration
{
	email admin@ionsignal.com
	# UNCOMMENT DURING INITIAL TESTING TO AVOID LETS ENCRYPT RATE LIMITS
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}
# Generate Wildcard Certificate via ACME-DNS Delegation
*.ionsignal.com {
	tls {
		dns acmedns /etc/caddy/acmedns.json
	}
	# Security Headers for the DMZ
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
	}
	# Route AI API Traffic (vllm/sglang)
	@ai host api.ionsignal.com
	handle @ai {
		reverse_proxy 10.10.10.50:8080 {
			# Disable buffering for zero-latency LLM token streaming (SSE)
			flush_interval -1
		}
	}
	# Route Incus UI & API Traffic
	@incus host incus.ionsignal.com
	handle @incus {
		# Protect the URL with your hashed password
		basic_auth {
			admin $2a$14$yEU3mdzE9W8NUTt7ke270ez./YsWYK8Grlwv8woLJD.S6RBAM6qhq
			dev $2a$14$y8vpwMOPy5cdud1IwhlsRuAPPPSk/xGku1jC7DuP7Kf6eJhtd.0k.
		}
		# Proxy to Incus and present the Client Certificate
		reverse_proxy 10.10.10.1:8443 {
			header_up Host {upstream_hostport}
			transport http {
				tls_insecure_skip_verify
				tls_client_auth /etc/caddy/incus-certs/caddy.crt /etc/caddy/incus-certs/caddy.key
			}
		}
	}
	# Fallback: Drop any requests to unconfigured subdomains
	handle {
		respond "404 Not Found - Unauthorized Subdomain" 404
	}
}
